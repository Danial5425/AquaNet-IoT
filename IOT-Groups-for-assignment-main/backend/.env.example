# AquaNet Backend Environment Config
# Copy this file to .env and edit values

# MQTT Broker
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Server
PORT=3001
HOST=0.0.0.0

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database
DB_PATH=./data/aquanet.db
